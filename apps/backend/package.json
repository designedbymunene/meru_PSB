{
  "name": "@meru/backend",
  "version": "1.0.0",
  "description": "Meru County Recruitment Portal Backend",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-heavy": "tsx src/db/seed-heavy.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:import-users-profiles": "tsx src/db/import-users-profiles.ts",
    "db:import-comprehensive": "tsx src/db/import-comprehensive.ts",
    "db:cleanup": "tsx src/db/cleanup.ts",
    "db:create-admin": "tsx src/db/create-admin.ts",
    "test": "tsx --test src/__tests__/**/*.test.ts",
    "test:vitest": "vitest run src/__tests__/application-flow.test.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "recruitment",
    "hono",
    "drizzle",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@meru/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.14",
    "hono-rate-limiter": "^0.5.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.10",
    "@types/pino": "^7.0.5",
    "drizzle-kit": "^0.31.8",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.1.2"
  }
}
