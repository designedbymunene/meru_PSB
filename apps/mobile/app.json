{
  "expo": {
    "name": "Meru County PSB",
    "slug": "meru-county-psb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/merucountylogo.png",
    "scheme": "merucountypsbmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/branding/merucountylogo.png",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to quickly and securely sign in to your Meru County PSB account."
      },
      "bundleIdentifier": "com.designedbymunene.merucountypsb"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/branding/merucountylogo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.designedbymunene.merucountypsb",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/branding/merucountylogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/branding/merucountylogo.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image",
      "expo-local-authentication",
      "expo-document-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/branding/merucountylogo.png",
          "color": "#208AEF",
          "sounds": ["./assets/notification.wav"]
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/8961bc58-ba56-4608-909b-397000a9ca71",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8961bc58-ba56-4608-909b-397000a9ca71"
      }
    },
    "owner": "designedbymunene"
  }
}